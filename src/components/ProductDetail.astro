---
// Full detail view for a single loan product. Used by the (bank, type) hub when
// the bank has exactly one product of that type, and by each variant page.
import { getBank, t } from '../lib/data.js';
import { loanTypeName } from '../lib/loanTypes.js';
import { url } from '../lib/url.js';

const { product, showHeading = false } = Astro.props;
const bank = getBank(product.bankId);
const typeName = t(loanTypeName(product.type));

const pdfUrl = (product.sources ?? []).find((s) => /\.pdf(\?|$)/i.test(s)) ?? null;
const pageUrl = (product.sources ?? []).find((s) => s !== pdfUrl) ?? null;
const docs = t(product.documents) ?? [];

const fmtAmount = (n) =>
  n == null ? '—' : n >= 1000000 ? `${(n / 1000000).toLocaleString('hy-AM')} մլն ֏` : `${n.toLocaleString('hy-AM')} ֏`;
const fmtTermRange = (min, max) => {
  const y = (m) => (m % 12 === 0 ? `${m / 12} տարի` : `${m} ամիս`);
  if (min == null && max == null) return '—';
  if (min == null) return `մինչև ${y(max)}`;
  if (max == null) return `${y(min)}-ից`;
  return `${y(min)} – ${y(max)}`;
};
const fmtRate = (min, max) =>
  min == null ? '—' : max != null && max !== min ? `${min}–${max}%` : `${min}%`;

const seedAmount = product.amountMin ?? 3000000;
const seedYears = product.termMonthsMax ? Math.round(product.termMonthsMax / 12) : 10;
const seedRate = product.effectiveRate ?? product.nominalRate ?? 14;

// Unique suffix so multiple calculators never share element ids
const uid = product.id.replace(/[^a-z0-9]/gi, '');
---

{showHeading && (
  <div class="profile-header">
    <h2>{t(product.name)}</h2>
    <span class="badge">{typeName}</span>
  </div>
)}

<div class="rates" style="display:flex;gap:var(--sp-6);flex-wrap:wrap;margin:var(--sp-4) 0 var(--sp-5);font-variant-numeric:tabular-nums">
  <div class="rate-block">
    <span class="value">{fmtRate(product.nominalRate, product.nominalRateMax)}</span>
    <span class="label">անվանական տոկոսադրույք</span>
  </div>
  <div class="rate-block effective">
    <span class="value">{fmtRate(product.effectiveRate, product.effectiveRateMax)}</span>
    <span class="label">փաստացի (ՓՏԴ)</span>
  </div>
</div>

<section class="card">
  <h3>Վարկի պայմանները</h3>
  <ul class="contact-list">
    <li><span class="label">Արժույթ</span><span>{product.currency ?? 'ՀՀ դրամ'}</span></li>
    <li><span class="label">Գումարը</span><span>{fmtAmount(product.amountMin)} – {fmtAmount(product.amountMax)}</span></li>
    <li><span class="label">Ժամկետը</span><span>{fmtTermRange(product.termMonthsMin, product.termMonthsMax)}</span></li>
    {product.downPaymentMinPct != null && (
      <li><span class="label">Կանխավճար</span><span>{product.downPaymentMinPct}%-ից</span></li>
    )}
    <li><span class="label">Անվանական տոկոսադրույք</span><span>{fmtRate(product.nominalRate, product.nominalRateMax)}</span></li>
    <li><span class="label">Փաստացի տոկոսադրույք</span><span>{fmtRate(product.effectiveRate, product.effectiveRateMax)}</span></li>
    {product.govPrograms?.length > 0 && (
      <li><span class="label">Պետական ծրագրեր</span><span>{product.govPrograms.join(', ')}</span></li>
    )}
    <li><span class="label">Թարմացվել է</span><span>{product.updatedAt}</span></li>
  </ul>
</section>

{product.notes && t(product.notes) && (
  <section class="card">
    <h3>Մանրամասներ</h3>
    <p>{t(product.notes)}</p>
  </section>
)}

{docs.length > 0 && (
  <section class="card">
    <h3>Անհրաժեշտ փաստաթղթեր</h3>
    <ul>{docs.map((d) => <li>{d}</li>)}</ul>
  </section>
)}

{(pdfUrl || pageUrl) && (
  <section class="card">
    <h3>Պաշտոնական աղբյուրներ</h3>
    <ul class="contact-list">
      {pdfUrl && (
        <li>
          <span class="label">Պայմանների PDF</span>
          <a href={pdfUrl} target="_blank" rel="noopener">📄 Ներբեռնել բանկի պաշտոնական պայմանները (PDF)</a>
        </li>
      )}
      {pageUrl && (
        <li>
          <span class="label">Բանկի էջ</span>
          <a href={pageUrl} target="_blank" rel="noopener">{pageUrl}</a>
        </li>
      )}
    </ul>
  </section>
)}

<div class="calc" id={`calc-${uid}`}>
  <h3>Ամսական վճարի հաշվիչ</h3>
  <div class="filters">
    <label>Գումար (AMD) <input type="number" id={`am-${uid}`} value={seedAmount} step="500000" /></label>
    <label>Ժամկետ (տարի) <input type="number" id={`yr-${uid}`} value={seedYears} min="1" max="30" /></label>
    <label>Տոկոսադրույք (%) <input type="number" id={`rt-${uid}`} value={seedRate} step="0.05" /></label>
  </div>
  <p>Ամսական վճար՝ <span class="calc-result" id={`mo-${uid}`}>—</span></p>
  <p><small>Ընդհանուր վճարվելիք՝ <span id={`to-${uid}`}>—</span> · Անուիտետային մոտավոր հաշվարկ է, ոչ առաջարկ։ Դաշտերը լրացված են այս վարկի պայմաններով։</small></p>
</div>

<p style="margin-top:var(--sp-6)">
  <a href={url(`/loans/${product.type}/`)}>→ Համեմատել {typeName}ը բոլոր բանկերի հետ</a><br />
  <a href={url(`/banks/${bank.id}/`)}>→ {t(bank.name)}ի ամբողջ պրոֆիլը</a>
</p>

<script define:vars={{ uid }}>
  (function () {
    const am = document.getElementById('am-' + uid);
    const yr = document.getElementById('yr-' + uid);
    const rt = document.getElementById('rt-' + uid);
    const mo = document.getElementById('mo-' + uid);
    const to = document.getElementById('to-' + uid);
    if (!am) return;
    function recalc() {
      const A = Number(am.value);
      const n = Number(yr.value) * 12;
      const r = Number(rt.value) / 100 / 12;
      if (!A || !n || !r) { mo.textContent = '—'; to.textContent = '—'; return; }
      const m = (A * r) / (1 - Math.pow(1 + r, -n));
      mo.textContent = Math.round(m).toLocaleString('hy-AM') + ' ֏';
      to.textContent = Math.round(m * n).toLocaleString('hy-AM') + ' ֏';
    }
    [am, yr, rt].forEach((el) => el.addEventListener('input', recalc));
    recalc();
  })();
</script>
