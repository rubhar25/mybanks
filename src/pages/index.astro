---
import Base from '../layouts/Base.astro';
import { banks } from '../lib/data.js';
import { t } from '../lib/data.js';
---

<Base title="Հայաստանի ֆինանսական պորտալ">
  <h1>Հայաստանի ֆինանսական պորտալ</h1>
  <p><a href="/loans/mortgage/">→ Հիփոթեքային վարկերի համեմատություն</a></p>
  <h2>Բանկերը</h2>
  <ul class="card-grid">
    {banks.map((bank) => (
      <li>
        <a class="card-link" href={`/banks/${bank.id}/`}>{t(bank.name)}</a>
      </li>
    ))}
  </ul>
</Base>
