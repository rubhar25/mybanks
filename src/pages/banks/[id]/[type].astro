---
import Base from '../../../layouts/Base.astro';
import ProductDetail from '../../../components/ProductDetail.astro';
import { products, getBank, t } from '../../../lib/data.js';
import { loanTypeName, isLoanType } from '../../../lib/loanTypes.js';
import { variantSlug } from '../../../lib/products.js';
import { url } from '../../../lib/url.js';

export function getStaticPaths() {
  // One hub per (bank, loan-type) that has at least one product.
  const seen = new Set();
  const paths = [];
  for (const p of products) {
    if (!isLoanType(p.type)) continue;
    const key = `${p.bankId}/${p.type}`;
    if (seen.has(key)) continue;
    seen.add(key);
    paths.push({ params: { id: p.bankId, type: p.type }, props: { bankId: p.bankId, type: p.type } });
  }
  return paths;
}

const { bankId, type } = Astro.props;
const bank = getBank(bankId);
const typeName = t(loanTypeName(type));
const items = products
  .filter((p) => p.bankId === bankId && p.type === type)
  .sort((a, b) => (a.effectiveRate ?? Infinity) - (b.effectiveRate ?? Infinity));

const single = items.length === 1;

const fmtRate = (min, max) =>
  min == null ? '—' : max != null && max !== min ? `${min}–${max}%` : `${min}%`;
---

<Base
  title={`${t(bank.name)} — ${typeName}. պայմաններ, տոկոսադրույք, փաստաթղթեր`}
  description={`${t(bank.name)} ${typeName}. ${items.length > 1 ? `${items.length} տեսակ, ` : ''}փաստացի տոկոսադրույք, պայմաններ, փաստաթղթեր և ամսական վճարի հաշվիչ։`}
>
  <nav class="breadcrumb">
    <a href={url(`/banks/${bank.id}/`)}>← {t(bank.name)}</a> ·
    <a href={url(`/loans/${type}/`)}>{typeName}՝ բոլոր բանկերը</a>
  </nav>

  <div class="profile-header">
    <h1>{t(bank.name)} — {typeName}</h1>
    {single && <span class="badge">{typeName}</span>}
  </div>

  {single ? (
    <ProductDetail product={items[0]} />
  ) : (
    <>
      <p class="muted">{t(bank.name)}ն առաջարկում է {typeName.toLowerCase()}ի {items.length} տեսակ։ Ընտրեք տեսակը՝ լրիվ պայմանները տեսնելու համար։</p>
      <ul class="card-grid">
        {items.map((p) => (
          <li>
            <a class="card-link" href={url(`/banks/${bank.id}/${type}/${variantSlug(p)}/`)} style="flex-direction:column;align-items:flex-start;gap:var(--sp-2)">
              <strong>{t(p.name)}</strong>
              <span class="muted">
                Փաստացի՝ {fmtRate(p.effectiveRate, p.effectiveRateMax)}
                {p.amountMax != null && ` · մինչև ${(p.amountMax / 1000000).toLocaleString('hy-AM')} մլն ֏`}
              </span>
            </a>
          </li>
        ))}
      </ul>
      <p><a href={url(`/loans/${type}/`)}>→ Համեմատել {typeName}ը բոլոր բանկերի հետ</a></p>
    </>
  )}
</Base>
