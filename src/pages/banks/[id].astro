---
import Base from '../../layouts/Base.astro';
import { banks, getProductsOfBank, t } from '../../lib/data.js';
import { url } from '../../lib/url.js';

export function getStaticPaths() {
  return banks.map((bank) => ({ params: { id: bank.id }, props: { bank } }));
}

const { bank } = Astro.props;
const bankProducts = getProductsOfBank(bank.id);
---

<Base title={`${t(bank.name)} — պրոֆիլ`}>
  <nav class="breadcrumb"><a href={url('/')}>← Բոլոր բանկերը</a></nav>

  <div class="profile-header">
    <h1>{t(bank.name)}</h1>
    <span class="badge" title="SWIFT / BIC">SWIFT՝ {bank.swift}</span>
  </div>
  <p class="muted">{t(bank.fullName)}</p>

  <section class="card">
    <h2>Կոնտակտներ</h2>
    <ul class="contact-list">
      {bank.phones.map((p) => (
        <li>
          <span class="label">{t(p.label)}</span>
          <a href={`tel:${p.number.replace(/\s/g, '')}`}>{p.number}</a>
        </li>
      ))}
      <li>
        <span class="label">Կայք</span>
        <a href={bank.website}>{bank.website}</a>
      </li>
      <li>
        <span class="label">Հասցե</span>
        <span>{t(bank.headOffice)}</span>
      </li>
    </ul>
  </section>

  <h2>Պրոդուկտներ</h2>
  {bankProducts.map((p) => (
    <article class="card product-card">
      <div>
        <h3>{t(p.name)}</h3>
        {p.type === 'mortgage' && (
          <a href={url('/loans/mortgage/')}>Համեմատել բոլոր բանկերի հետ</a>
        )}
        {p.type === 'deposit' && (
          <a href={url('/deposits/')}>Համեմատել բոլոր բանկերի հետ</a>
        )}
      </div>
      <div class="rates">
        <div class="rate-block">
          <span class="value">{p.nominalRate}%</span>
          <span class="label">անվանական</span>
        </div>
        <div class="rate-block effective">
          <span class="value">{p.effectiveRate}%</span>
          <span class="label">փաստացի</span>
        </div>
      </div>
    </article>
  ))}

  <p class="updated-stamp">Թարմացվել է՝ {bank.updatedAt}</p>
</Base>
