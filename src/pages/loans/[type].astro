---
import Base from '../../layouts/Base.astro';
import { products, getBank, t } from '../../lib/data.js';
import { loanTypes, loanTypeName } from '../../lib/loanTypes.js';
import { variantSlug } from '../../lib/products.js';
import { url } from '../../lib/url.js';

export function getStaticPaths() {
  // One page per loan type that actually has product data.
  const typesWithData = loanTypes
    .map((l) => l.type)
    .filter((type) => products.some((p) => p.type === type));
  return typesWithData.map((type) => ({ params: { type }, props: { type } }));
}

const { type } = Astro.props;
const name = t(loanTypeName(type));

const loans = products
  .filter((p) => p.type === type)
  // Sort by effective rate; products without one (rate not published) go last.
  .sort((a, b) => (a.effectiveRate ?? Infinity) - (b.effectiveRate ?? Infinity));

// Show the down-payment column only when it's meaningful for this loan type
const showDownPayment = loans.some((p) => p.downPaymentMinPct != null);

// Market context is computed only over products that actually publish an effective rate
const effRates = loans.map((p) => p.effectiveRate).filter((r) => r != null);
const hasContext = effRates.length > 0;
const effMin = hasContext ? Math.min(...effRates) : null;
const effMax = hasContext
  ? Math.max(...loans.map((p) => p.effectiveRateMax ?? p.effectiveRate).filter((r) => r != null))
  : null;
const effAvg = hasContext ? effRates.reduce((s, r) => s + r, 0) / effRates.length : null;
const lastUpdated = loans.map((p) => p.updatedAt).sort().at(-1);

const fmtAmount = (n) =>
  n == null ? '—' : n >= 1000000 ? `${(n / 1000000).toLocaleString('hy-AM')} մլն` : n.toLocaleString('hy-AM');
const fmtTerm = (min, max) => {
  const y = (m) => (m % 12 === 0 ? `${m / 12} տ` : `${m} ամիս`);
  if (min == null && max == null) return '—';
  if (min == null) return `մինչև ${y(max)}`;
  return `${y(min)} – ${y(max)}`;
};
const fmtRate = (min, max) =>
  min == null ? '—' : max != null && max !== min ? `${min}–${max}%` : `${min}%`;
---

<Base title={`${name}. համեմատություն — Հայաստանի բոլոր բանկերը`}>
  <nav class="breadcrumb"><a href={url('/loans/')}>← Վարկեր</a></nav>
  <h1>{name}. համեմատություն</h1>

  <div class="context">
    <strong>Շուկան այս պահին.</strong> {loans.length} բանկի պայմաններ
    {hasContext && (
      <> · փաստացի տոկոսադրույք՝ {effMin}%-ից {effMax}% · միջին նվազագույն ՓՏԴ՝ {effAvg.toFixed(2)}%</>
    )} ·
    <span class="updated-stamp">թարմացվել է՝ {lastUpdated}</span>
  </div>

  <div class="filters">
    <label>
      Վարկի գումարը (AMD)
      <input type="number" id="f-amount" placeholder="օր.՝ 3000000" step="500000" min="0" />
    </label>
    <label>
      Ժամկետը (տարի)
      <input type="number" id="f-term" placeholder="օր.՝ 5" min="1" max="30" />
    </label>
  </div>

  <div class="table-wrap">
    <table id="cmp">
      <thead>
        <tr>
          <th scope="col">Բանկ</th>
          <th scope="col" class="num">Անվանական</th>
          <th scope="col" class="num">Փաստացի (ՓՏԴ) ↑</th>
          <th scope="col" class="num">Ժամկետ</th>
          <th scope="col" class="num">Գումար (AMD)</th>
          {showDownPayment && <th scope="col" class="num">Կանխավճար</th>}
          <th scope="col"></th>
        </tr>
      </thead>
      <tbody>
        {loans.map((p) => {
          const bank = getBank(p.bankId);
          return (
            <tr
              data-amount-min={p.amountMin ?? ''}
              data-amount-max={p.amountMax ?? ''}
              data-term-min={p.termMonthsMin ?? ''}
              data-term-max={p.termMonthsMax ?? ''}
              data-rate={p.nominalRate}
            >
              <td>
                <a href={url(`/banks/${bank.id}/`)}>{t(bank.name)}</a>
                <br /><small class="muted">{t(p.name)}</small>
              </td>
              <td class="num">{fmtRate(p.nominalRate, p.nominalRateMax)}</td>
              <td class="num eff">{fmtRate(p.effectiveRate, p.effectiveRateMax)}</td>
              <td class="num">{fmtTerm(p.termMonthsMin, p.termMonthsMax)}</td>
              <td class="num">{fmtAmount(p.amountMin)} – {fmtAmount(p.amountMax)}</td>
              {showDownPayment && (
                <td class="num">{p.downPaymentMinPct == null ? '—' : `${p.downPaymentMinPct}%-ից`}</td>
              )}
              <td class="actions">
                <button class="calc-btn" type="button">Հաշվել</button>
                <a class="more-link" href={url(`/banks/${bank.id}/${type}/${variantSlug(p)}/`)}>Ավելին →</a>
              </td>
            </tr>
          );
        })}
      </tbody>
    </table>
  </div>
  <p><small>ՓՏԴ = փաստացի տոկոսադրույք, ներառում է բոլոր վճարները։ Աղբյուրը՝ բանկերի պաշտոնական էջերը։ «—» նշանակում է՝ բանկը այդ պայմանը հրապարակել չի։</small></p>

  <div class="calc" id="calc">
    <h2>Ամսական վճարի հաշվիչ</h2>
    <div class="filters">
      <label>Գումար (AMD) <input type="number" id="c-amount" value="3000000" step="500000" /></label>
      <label>Ժամկետ (տարի) <input type="number" id="c-years" value="5" min="1" max="30" /></label>
      <label>Տոկոսադրույք (%) <input type="number" id="c-rate" value="14" step="0.05" /></label>
    </div>
    <p>Ամսական վճար՝ <span class="calc-result" id="c-monthly">—</span></p>
    <p><small>Ընդհանուր վճարվելիք՝ <span id="c-total">—</span> · Անուիտետային մոտավոր հաշվարկ է, ոչ առաջարկ։</small></p>
  </div>

  <script>
    const rows = [...document.querySelectorAll('#cmp tbody tr')];
    const fAmount = document.getElementById('f-amount');
    const fTerm = document.getElementById('f-term');

    function applyFilters() {
      const amount = Number(fAmount.value) || null;
      const termMonths = fTerm.value ? Number(fTerm.value) * 12 : null;
      for (const row of rows) {
        const aMin = row.dataset.amountMin ? Number(row.dataset.amountMin) : null;
        const aMax = row.dataset.amountMax ? Number(row.dataset.amountMax) : null;
        const tMin = row.dataset.termMin ? Number(row.dataset.termMin) : null;
        const tMax = row.dataset.termMax ? Number(row.dataset.termMax) : null;
        let ok = true;
        if (amount != null) {
          if (aMin != null && amount < aMin) ok = false;
          if (aMax != null && amount > aMax) ok = false;
        }
        if (termMonths != null) {
          if (tMin != null && termMonths < tMin) ok = false;
          if (tMax != null && termMonths > tMax) ok = false;
        }
        row.classList.toggle('hidden', !ok);
      }
    }
    fAmount.addEventListener('input', applyFilters);
    fTerm.addEventListener('input', applyFilters);

    const cAmount = document.getElementById('c-amount');
    const cYears = document.getElementById('c-years');
    const cRate = document.getElementById('c-rate');
    const cMonthly = document.getElementById('c-monthly');
    const cTotal = document.getElementById('c-total');

    function recalc() {
      const A = Number(cAmount.value);
      const n = Number(cYears.value) * 12;
      const r = Number(cRate.value) / 100 / 12;
      if (!A || !n || !r) { cMonthly.textContent = '—'; cTotal.textContent = '—'; return; }
      const m = (A * r) / (1 - Math.pow(1 + r, -n));
      cMonthly.textContent = Math.round(m).toLocaleString('hy-AM') + ' ֏';
      cTotal.textContent = Math.round(m * n).toLocaleString('hy-AM') + ' ֏';
    }
    [cAmount, cYears, cRate].forEach((el) => el.addEventListener('input', recalc));
    recalc();

    document.querySelectorAll('.calc-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const row = btn.closest('tr');
        if (row.dataset.rate) cRate.value = row.dataset.rate;
        if (fAmount.value) cAmount.value = fAmount.value;
        if (fTerm.value) cYears.value = fTerm.value;
        recalc();
        document.getElementById('calc').scrollIntoView({ behavior: 'smooth' });
      });
    });
  </script>
</Base>
